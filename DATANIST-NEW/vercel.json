{
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/app/static/$1",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "/(.*)",
      "dest": "index.py",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"]
    }
  ],
  "env": {
    "FLASK_APP": "index.py",
    "FLASK_ENV": "production",
    "PYTHONUNBUFFERED": "1"
  }
}
